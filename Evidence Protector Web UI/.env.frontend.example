# =====================================================
# EVIDENCE PROTECTOR - FRONTEND CONFIGURATION
# =====================================================
# Copy this file to .env.local and fill in your values
# NEVER commit real credentials to version control

# === API Configuration ===
# Backend API endpoint (adjust host/port as needed)
VITE_API_BASE_URL=http://localhost:8000/api
VITE_API_TIMEOUT=30000

# === Development Configuration ===
# Development server port
VITE_PORT=5173

# Development server host
VITE_HOST=127.0.0.1

# Development mode
VITE_DEV_MODE=true

# === Analytics & Monitoring (Optional) ===
# Disable in development, enable in production
VITE_ENABLE_ANALYTICS=false

# === Logging ===
# Frontend log level: trace, debug, info, warn, error
VITE_LOG_LEVEL=debug

# === Security ===
# Content Security Policy (CSP) settings
# Set to 'true' to enable strict CSP
VITE_STRICT_CSP=false

# === Debug Mode ===
# Enable debug logs in browser console
VITE_DEBUG=true

# === Theme Configuration ===
# Default theme: light, dark, system
VITE_DEFAULT_THEME=system

# === API Authentication ===
# API Key for backend authentication (if required)
# VITE_API_KEY=your-api-key-here
# Note: Only for development. Use environment-specific keys in production.

# === Session Configuration ===
# Session check interval (ms)
VITE_SESSION_CHECK_INTERVAL=60000

# === Cache Configuration ===
# Enable service worker / offline support
VITE_ENABLE_SERVICE_WORKER=false

# Cache max age in seconds
VITE_CACHE_MAX_AGE=3600

# === Feature Flags ===
# Enable experimental features (development only)
VITE_ENABLE_EXPERIMENTAL_FEATURES=false

# === External Services ===
# Examples for if you integrate with external services
# VITE_SENTRY_DSN=
# VITE_MIXPANEL_TOKEN=
# VITE_SEGMENT_API_KEY=

# === Build Configuration ===
# Source maps in production
VITE_SOURCEMAP=false

# === Monitoring & Observability ===
# Error tracking (optional)
# VITE_ERROR_TRACKING_ENABLED=false

# Health check endpoint interval (ms)
VITE_HEALTH_CHECK_INTERVAL=60000
