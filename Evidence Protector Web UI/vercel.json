{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "nodeVersion": "20.x",
  "env": {
    "VITE_API_BASE_URL": {
      "description": "Backend API endpoint (Render service URL)",
      "example": "https://evidence-protector-backend.onrender.com/api"
    },
    "VITE_API_TIMEOUT": "30000",
    "VITE_LOG_LEVEL": "info"
  },
  "functions": {
    "api/**": {
      "runtime": "python@3.13"
    }
  }
}
