# ============================================
# EVIDENCE PROTECTOR - BACKEND CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit real credentials to version control

# === API Configuration ===
# API server port
EVIDENCE_PROTECTOR_API_PORT=8000

# API host (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
EVIDENCE_PROTECTOR_API_HOST=127.0.0.1

# === Authentication & Authorization ===
# Single legacy API key (DEPRECATED: prefer EVIDENCE_PROTECTOR_API_KEYS_JSON)
# Format: EVIDENCE_PROTECTOR_API_KEY=your-secret-key-here
# EVIDENCE_PROTECTOR_API_KEY=

# Role-based API keys (recommended)
# Format JSON: {"key1": "role1", "key2": "role2"}
# Roles: viewer, analyst, admin
# EVIDENCE_PROTECTOR_API_KEYS_JSON={"viewer-key":"viewer","analyst-key":"analyst","admin-key":"admin"}

# === Cryptographic Keys ===
# Path to Ed25519 private key for signing (optional, auto-generated if missing)
# EVIDENCE_PROTECTOR_PRIVATE_KEY_PATH=/path/to/private.key

# === Logging ===
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file location (optional)
LOG_FILE=./logs/evidence-protector.log

# === Security ===
# Enable CORS (only set for development/testing)
# EVIDENCE_PROTECTOR_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Enable debug mode (NEVER in production)
DEBUG=false

# === Frontend Integration ===
# Frontend URL for reverse proxy / CORS
FRONTEND_URL=http://localhost:3000

# === Session & Token Config ===
# Session timeout in seconds
SESSION_TIMEOUT=3600

# Token expiration in seconds
TOKEN_EXPIRATION=86400

# === Audit & Compliance ===
# Enable audit logging
ENABLE_AUDIT_LOG=true

# Audit log path
AUDIT_LOG_PATH=./logs/audit.log

# === Advanced ===
# Performance: Max workers for processing
MAX_WORKERS=4

# File upload size limit (bytes)
MAX_UPLOAD_SIZE=104857600

# Cache size limit
CACHE_SIZE=1000

# === External Services ===
# Any external service credentials (if applicable)
# EXAMPLE_SERVICE_API_KEY=
# EXAMPLE_SERVICE_SECRET=

# === Monitoring ===
# Prometheus metrics port (optional)
METRICS_PORT=9090

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=30
